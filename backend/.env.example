# Environment
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/trading_agent
DB_MAX_POOL_SIZE=10
DB_SERVER_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000
DB_BUFFER_COMMANDS=false
DB_BUFFER_MAX_ENTRIES=0

# Redis
REDIS_URL=redis://localhost:6379
REDIS_RETRY_DELAY=100
REDIS_MAX_RETRIES=3
REDIS_KEEP_ALIVE=30000

# JWT
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=trading-agent-platform
JWT_AUDIENCE=trading-agent-users

# Frontend
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_SKIP_SUCCESSFUL=false

# File Upload
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp
UPLOAD_DIR=uploads

# Email (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@trading-agent.com

# Trading Engine
TRADING_DEFAULT_BALANCE=10000
TRADING_MAX_POSITIONS=10
TRADING_RISK_LIMIT=0.02
TRADING_COMMISSION_RATE=0.001
TRADING_SLIPPAGE_RATE=0.0005
MARKET_DATA_UPDATE_INTERVAL=1000
SIGNAL_RETENTION_TIME=3600

# Backtest
BACKTEST_MAX_DURATION=365
BACKTEST_DEFAULT_TIMEFRAME=1h
BACKTEST_MAX_CONCURRENT=5
BACKTEST_RESULT_RETENTION_DAYS=30

# Battle System
BATTLE_DEFAULT_DURATION=24
BATTLE_MAX_DURATION=168
BATTLE_MIN_PARTICIPANTS=2
BATTLE_MAX_PARTICIPANTS=10
BATTLE_ENTRY_FEE=0
BATTLE_PRIZE_POOL_PERCENTAGE=0.9

# WebSocket
WS_PING_TIMEOUT=60000
WS_PING_INTERVAL=25000
WS_MAX_CONNECTIONS=1000

# Logging
LOG_LEVEL=debug
LOG_MAX_FILES=5
LOG_MAX_SIZE=20m
LOG_DIR=logs

# Security
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000
SESSION_TIMEOUT=3600000

# Cache
CACHE_DEFAULT_TTL=3600
CACHE_AGENT_LIST_TTL=300
CACHE_USER_PROFILE_TTL=1800
CACHE_TRADING_DATA_TTL=60
CACHE_LEADERBOARD_TTL=600

# External APIs
MARKET_DATA_PROVIDER=mock
MARKET_DATA_API_KEY=your-market-data-api-key
MARKET_DATA_BASE_URL=https://api.marketdata.com
NEWS_API_KEY=your-news-api-key
NEWS_API_BASE_URL=https://newsapi.org/v2

# Monitoring
ENABLE_METRICS=false
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30000
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=80
ALERT_RESPONSE_TIME_THRESHOLD=5000